{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "KASSA Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173,
      "autoPort": true
